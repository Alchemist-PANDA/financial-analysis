# ── API KEYS ───────────────────────────────────────────────────
# Get Groq key at: https://console.groq.com (Recommended for Free Tier)
GROQ_API_KEY=gsk_your_key_here

# Get Tavily key at: https://tavily.com (For AI search/news integration)
TAVILY_API_KEY=tvly-your-key-here

# (Optional) Google API Key for fallback
GOOGLE_API_KEY=AIzaSy_your_key_here

# ── APP SECURITY ───────────────────────────────────────────────
# Set a strong random password for backend/frontend communication
API_SECRET_KEY=your_secure_random_token_here

# ── DATABASE ───────────────────────────────────────────────────
# Local development: leave empty to use 'financial_agent.db' (SQLite)
# Production: paste your Neon.tech Connection String here
DATABASE_URL=postgres://user:pass@ep-pool-name.region.aws.neon.tech/neondb?sslmode=require

# ── CORS / FRONTEND ───────────────────────────────────────────
# Backend only: comma-separated list of allowed frontend URLs
# Example: http://localhost:3000,https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── FRONTEND ONLY (NEXT.JS) ──────────────────────────────────
# Prefix with NEXT_PUBLIC_ to make them accessible to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=your_secure_random_token_here (Match API_SECRET_KEY)
